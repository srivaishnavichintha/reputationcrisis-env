# Option A (default — recommended for dev):
# Leave VITE_API_URL blank → frontend uses /api/* which Vite proxies to localhost:8000
# This avoids all CORS issues.
VITE_API_URL=

# Option B (if Vite proxy isn't working or you're running frontend separately):
# Uncomment and set this to point directly at the backend.
# Make sure backend CORS allows your frontend origin.
# VITE_API_URL=http://localhost:8000
